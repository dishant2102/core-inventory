{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "outDir": "../../dist/out-tsc",
        "types": [
            "vite/client"
        ],
        "paths": {
            "@admin/*": [
                "apps/admin/src/*"
            ],
            "@libs/types": [
                "packages/types/src"
            ],
            "@libs/utils": [
                "packages/utils/src"
            ],
            "@libs/react-shared": [
                "packages/react-shared/src"
            ]
        }
    },
    "exclude": [
        "jest.config.ts",
        "src/**/*.spec.ts",
        "src/**/*.test.ts",
        "src/**/*.spec.tsx",
        "src/**/*.test.tsx",
        "src/**/*.spec.js",
        "src/**/*.test.js",
        "src/**/*.spec.jsx",
        "src/**/*.test.jsx",
        "vite.config.ts",
        "vitest.config.ts"
    ],
    "include": [
        "src/**/*.js",
        "src/**/*.jsx",
        "src/**/*.ts",
        "src/**/*.tsx"
    ]
}
