import { IsString, IsOptional, IsBoolean, IsNumber, IsEnum, IsUUID, IsDate, IsObject } from 'class-validator';
<% if (swagger) { -%>
import { ApiProperty } from '@nestjs/swagger';
<% } -%>
<% if (enumColumns.length > 0) { -%>
import { <%= enumColumns.map(c => c.enumTypeName).join(', ') %> } from '@libs/types';
<% } -%>

export class Create<%= entityPascal %>Dto {
<% for (const col of columns) { -%>
    <%_ if (swagger) { -%>
    <%- col.swaggerDecorator %>
    <%_ } -%>
    <%_ if (col.dbType === 'string' || col.dbType === 'text') { -%>
    @IsString()
    <%_ } else if (col.dbType === 'boolean') { -%>
    @IsBoolean()
    <%_ } else if (col.dbType === 'int' || col.dbType === 'float') { -%>
    @IsNumber()
    <%_ } else if (col.dbType === 'uuid') { -%>
    @IsUUID()
    <%_ } else if (col.dbType === 'date' || col.dbType === 'datetime') { -%>
    @IsDate()
    <%_ } else if (col.dbType === 'json') { -%>
    @IsObject()
    <%_ } else if (col.dbType === 'enum') { -%>
    @IsEnum(<%= col.enumTypeName %>)
    <%_ } -%>
    <%_ if (col.optional) { -%>
    @IsOptional()
    <%_ } -%>
    <%= col.propertyName %><%= col.optional ? '?' : '' %>: <%= col.tsType %>;

<% } -%>
}
