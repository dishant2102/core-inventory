import { QueryBuilder, WhereOperatorEnum } from '@ackplus/nest-crud-request';
import { use<%= entityPascal %>List, useDelete<%= entityPascal %> } from '@libs/react-shared';
import { I<%= entityPascal %> } from '@libs/types';
import { toDisplayDate } from '@libs/utils';
import { Button, Card } from '@mui/material';
import { useCallback, useEffect, useMemo, useRef, useState } from 'react';
import { Link, useNavigate } from 'react-router-dom';

import { Page, Icon } from '../../components';
import { CrudTable, CrudTableActions } from '../../components/crud/crud-table';
import { DataTableColumn, DataTableTab, DataTableTabItem, IDataTableFilter } from '../../components/data-table';
import { IconEnum } from '../../components/icons/icons';
import { PATH_DASHBOARD } from '../../routes/paths';

<%_ if (viewType !== 'page') { -%>
import AddEdit<%= entityPascal %>Form from '../../sections/<%= pluralKebab %>/add-edit-<%= entityFile %>-form';
<%_ } -%>

// eslint-disable-next-line @typescript-eslint/no-empty-interface
export interface I<%= entityPascal %>TableFilter {
}

const defaultFilter: I<%= entityPascal %>TableFilter = {
};

export default function <%= entityPascal %>ListPage() {
    const navigate = useNavigate();
    const datatableRef = useRef<CrudTableActions>(null);
    const [tableFilter, setTableFilter] = useState(defaultFilter);

<%_ if (viewType !== 'page') { -%>
    const [openForm, setOpenForm] = useState(false);
    const [selectedId, setSelectedId] = useState<string | null>(null);

    const handleCloseForm = useCallback(() => {
        setOpenForm(false);
        setSelectedId(null);
        datatableRef.current?.refresh();
    }, []);
<%_ } -%>

    const handleEdit = useCallback(
        (row: I<%= entityPascal %>) => {
<%_ if (viewType === 'page') { -%>
            navigate(PATH_DASHBOARD.<%= entityCamel %>.edit(row.id));
<%_ } else { -%>
            setSelectedId(row.id);
            setOpenForm(true);
<%_ } -%>
        },
        [navigate],
    );

    const handleView = useCallback(
        (row: I<%= entityPascal %>) => {
<%_ if (viewType === 'page') { -%>
            navigate(PATH_DASHBOARD.<%= entityCamel %>.view(row.id));
<%_ } else { -%>
            setSelectedId(row.id);
            setOpenForm(true);
<%_ } -%>
        },
        [navigate],
    );

    const handleDataTableApiRequestMap = useCallback(
        (queryBuilder: QueryBuilder, request: IDataTableFilter) => {
            if (request?.search) {
                queryBuilder.orWhere('name', WhereOperatorEnum.ILIKE, `%${request?.search}%`);
            }
            return queryBuilder;
        },
        [],
    );

    const tabs: DataTableTabItem[] = useMemo(() => {
        return [
            {
                value: 'all',
                label: 'All',
                count: 0,
            },
        ];
    }, []);

    const columns: DataTableColumn<I<%= entityPascal %>>[] = [
<%_ for (const col of columns.slice(0, 6)) { -%>
        {
            name: '<%= col.propertyName %>',
            label: '<%= col.label %>',
            isSortable: true,
            isSearchable: true,
<%_ if (col.dbType === 'date' || col.dbType === 'datetime') { -%>
            render: (row) => toDisplayDate(row?.<%= col.propertyName %>),
<%_ } else if (col.dbType === 'boolean') { -%>
            render: (row) => (row?.<%= col.propertyName %> ? 'Yes' : 'No'),
<%_ } else { -%>
            render: (row) => row?.<%= col.propertyName %>,
<%_ } -%>
        },
<%_ } -%>
        {
            name: 'createdAt',
            label: 'Created Date',
            isSortable: true,
            render: (row) => toDisplayDate(row?.createdAt),
        },
    ];

    return (
        <Page
            title="<%= entityPascal %> List"
            breadcrumbs={[
                { name: 'Dashboard', href: PATH_DASHBOARD.root },
                { name: '<%= entityPascal %>', href: PATH_DASHBOARD.<%= entityCamel %>.root },
                { name: 'List' },
            ]}
        >
            <Card>
                <DataTableTab tabs={tabs} value="all" onChange={() => {}} />
                <CrudTable
                    crudName="<%= entityPascal %>"
                    columns={columns}
                    ref={datatableRef}
                    canEdit={true}
                    canDelete={true}
                    dataTableApiRequestMap={handleDataTableApiRequestMap}
                    crudOperationHooks={{
                        useGetMany: use<%= entityPascal %>List,
                        useDelete: useDelete<%= entityPascal %>,
                    }}
                    onEdit={handleEdit}
                    onRowClick={handleView}
                    extraFilter={(
                        <Button
<%_ if (viewType === 'page') { -%>
                            component={Link}
                            to={PATH_DASHBOARD.<%= entityCamel %>.add}
<%_ } else { -%>
                            onClick={() => { setSelectedId(null); setOpenForm(true); }}
<%_ } -%>
                            variant="contained"
                            startIcon={<Icon icon={IconEnum.Add} />}
                        >
                            New <%= entityPascal %>
                        </Button>
                    )}
                />
            </Card>

<%_ if (viewType !== 'page') { -%>
            {openForm && (
                <AddEdit<%= entityPascal %>Form
                    open={openForm}
                    onClose={handleCloseForm}
                    id={selectedId}
                />
            )}
<%_ } -%>
        </Page>
    );
}
